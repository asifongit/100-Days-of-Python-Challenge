   "source": [
    "Write a program to find the euclidean distance between two\n",
    "coordinates."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "27313552",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "5.0\n"
     ]
    }
   ],
   "source": [
    "import math\n",
    "\n",
    "point1=(3,4)\n",
    "point2=(7,1)\n",
    "\n",
    "dx=point1[0]-point2[0]\n",
    "dy=point1[1]-point2[1]\n",
    "\n",
    "\n",
    "squaredx=dx*dx \n",
    "squaredy=dy*dy\n",
    "\n",
    "\n",
    "\n",
    "sum= squaredx+ squaredy\n",
    "\n",
    "squarroot=math.sqrt(sum)\n",
    "print(squarroot)"
   ]
  },
