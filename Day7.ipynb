   "metadata": {},
   "source": [
    "Write a program that will tell whether the given year is a leap year\n",
    "or not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "23b5eb82",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2005 is not a leap year\n"
     ]
    }
   ],
   "source": [
    "a=int(input(\"Enter the years: \"))\n",
    "if a%400==0:\n",
    "    print(f\"{a} is a leap year\")\n",
    "else:\n",
    "    if a%4==0 and a%100!=0:\n",
    "        print(f\"{a} is a leap year\")\n",
    "    else:\n",
    "        print(f\"{a} is not a leap year\")"
   ]
  },
